---
<section class="hero">
  <h1 class="typewriter">
    <span class="typewriter-text"></span>
  </h1>
</section>

<script>
  import { generateFrames, defaultConfig } from '../utils/typewriter';

  const el = document.querySelector('.typewriter-text');
  if (el) {
    const frames = generateFrames();
    const { typeSpeed, deleteSpeed, retypeSpeed, pauseBeforeDelete, pauseBeforeRetype, firstWord, suffix } = defaultConfig;
    const full = firstWord + suffix;

    let i = 0;
    const phaseOneEnd = full.length + 1;
    const phaseTwoEnd = phaseOneEnd + firstWord.length;

    function render(frame: { accent: string; plain: string }) {
      if (frame.accent.length === 0) {
        el!.innerHTML = frame.plain;
      } else {
        el!.innerHTML = '<span class="accent">' + frame.accent + '</span>' + frame.plain;
      }
    }

    function tick() {
      if (i >= frames.length) return;
      render(frames[i]);
      i++;

      if (i === phaseOneEnd) {
        setTimeout(tick, pauseBeforeDelete);
      } else if (i === phaseTwoEnd) {
        setTimeout(tick, pauseBeforeRetype);
      } else if (i <= phaseOneEnd) {
        setTimeout(tick, typeSpeed);
      } else if (i <= phaseTwoEnd) {
        setTimeout(tick, deleteSpeed);
      } else {
        setTimeout(tick, retypeSpeed);
      }
    }

    tick();
  }
</script>
